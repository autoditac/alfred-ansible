[Unit]
Description=Alfred Dashboard (status & control UI)
After=network-online.target sunray.service
Wants=network-online.target

[Container]
Image=ghcr.io/autoditac/alfred-dashboard:{{ alfred_dashboard_image_tag }}
ContainerName=alfred-dashboard
Network=host
Environment=SUNRAY_HOST=127.0.0.1
Environment=SUNRAY_PORT=80
Environment=PORT=3000
Environment=TZ=Europe/Copenhagen
{% if alfred_dock_lat is defined and alfred_dock_lon is defined %}
Environment=DOCK_LAT={{ alfred_dock_lat }}
Environment=DOCK_LON={{ alfred_dock_lon }}
{% endif %}
AutoUpdate=registry
PodmanArgs=--init

[Service]
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target default.target
