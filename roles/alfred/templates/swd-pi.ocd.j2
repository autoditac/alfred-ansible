# OpenOCD SWD config for {{ alfred_board }}
# Generated by Ansible — do not edit manually

{% set gpio = alfred_swd_gpio[alfred_board] %}
{% if alfred_mcu == 'main' %}
{% set srst_num = gpio.srst_main %}
{% else %}
{% set srst_num = gpio.srst_peri %}
{% endif %}

{% if gpio.driver == 'linuxgpiod' %}
adapter driver linuxgpiod
adapter gpio swdio {{ gpio.swdio }} -chip {{ gpio.chip }}
adapter gpio swclk {{ gpio.swclk }} -chip {{ gpio.chip }}
adapter gpio srst {{ srst_num }} -chip {{ gpio.chip }}
{% else %}
interface sysfsgpio
sysfsgpio_swdio_num {{ gpio.swdio }}
sysfsgpio_swclk_num {{ gpio.swclk }}
sysfsgpio_srst_num {{ srst_num }}
{% endif %}

transport select swd

reset_config srst_only
reset_config srst_nogate
reset_config connect_assert_srst

source [find target/stm32f1x.cfg]

adapter srst delay 100
adapter srst pulse_width 100
